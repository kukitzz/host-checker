# =============================================================================
# host-checker — environment variables
# =============================================================================
# Copy this file to `.env` and fill in only the keys for the providers you
# want to enable. Providers without a key are skipped silently unless they
# work keyless (e.g. tor_exit, crtsh).
#
# All keys here are FREE to obtain. None of them require a paid plan to
# get started.
# =============================================================================

# VirusTotal — https://www.virustotal.com/gui/my-apikey
# Free tier: 4 requests/min, 500/day. Supports IP, domain, URL, hash.
HC_VIRUSTOTAL_API_KEY=

# AbuseIPDB — https://www.abuseipdb.com/account/api
# Free tier: 1000 checks/day. Supports IP only.
HC_ABUSEIPDB_API_KEY=

# GreyNoise (Community) — https://viz.greynoise.io/account/
# Free community tier: 50 lookups/day. Supports IP only. Great for
# reducing false positives from internet-wide scanners.
HC_GREYNOISE_API_KEY=

# AlienVault OTX — https://otx.alienvault.com/api
# Free. Supports IP, domain, URL, hash. (Provider not implemented yet —
# see providers/README.md for how to add it.)
HC_OTX_API_KEY=

# abuse.ch — https://auth.abuse.ch/
# Free Auth-Key shared across URLhaus, ThreatFox, MalwareBazaar.
# host-checker queries URLhaus public bulk feed without a key, but with
# this key you get richer per-IOC queries.
HC_ABUSECH_AUTH_KEY=

# Shodan — https://account.shodan.io/
# One-time $5 unlocks the API. Supports IP.
HC_SHODAN_API_KEY=

# IPinfo — https://ipinfo.io/account/token
# Optional: works keyless at low volume. Free token grants 50k/month.
# Supports IP. The paid privacy add-on unlocks VPN/proxy/Tor detection.
HC_IPINFO_API_KEY=

# -----------------------------------------------------------------------------
# Auto-pivot: when checking a domain, resolve it via DNS and check the
# resulting IPs too. Set to `false` to disable. `HC_PIVOT_LIMIT` caps how
# many IPs per domain (default 5).
# -----------------------------------------------------------------------------
HC_AUTO_PIVOT=true
HC_PIVOT_LIMIT=5

# -----------------------------------------------------------------------------
# Optional: path to an allowlist file (one IP / CIDR / domain per line).
# IOCs matching the allowlist are short-circuited as CLEAN and never sent
# to any upstream provider. Lines starting with `#` are comments.
# -----------------------------------------------------------------------------
HC_ALLOWLIST_FILE=
